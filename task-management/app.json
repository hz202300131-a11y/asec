{
  "expo": {
    "name": "Task Management",
    "slug": "task-management",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/task-management-logo.png",
    "scheme": "taskmanagement",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/task-management-logo.png",
        "backgroundImage": "./assets/task-management-logo.png",
        "monochromeImage": "./assets/task-management-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.earlkian8.taskmanagement"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5d342b17-1f6a-482d-8264-9a2491e1033f"
      }
    },
    "owner": "hz202300131s-organization"
  }
}
